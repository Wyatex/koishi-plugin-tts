{
  "name": "@wyatex/koishi-plugin-tts",
  "description": "为 YesImBot 提供TTS(文本转语音)功能",
  "version": "0.0.6",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "homepage": "https://github.com/Wyatex/koishi-plugin-tts",
  "files": [
    "lib",
    "dist",
    "resources"
  ],
  "contributors": [
    "MiaowFISH <neko-project@outlook.com>"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsc -w --preserveWatchOutput",
    "lint": "eslint . --ext .ts",
    "clean": "rm -rf lib .turbo tsconfig.tsbuildinfo",
    "pack": "bun pm pack"
  },
  "license": "MIT",
  "keywords": [
    "chatbot",
    "koishi",
    "plugin",
    "ai",
    "yesimbot"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Wyatex/koishi-plugin-tts.git"
  },
  "bugs": {
    "url": "https://github.com/Wyatex/koishi-plugin-tts/issues"
  },
  "exports": {
    ".": "./lib/index.js",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.2"
  },
  "devDependencies": {
    "koishi": "^4.18.7",
    "koishi-plugin-yesimbot": "^3.0.2",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "yml-register": "^1.2.5"
  },
  "peerDependencies": {
    "koishi": "^4.18.7",
    "koishi-plugin-yesimbot": "^3.0.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "koishi": {
    "description": {
      "zh": "为 YesImBot 提供TTS(文本转语音)功能",
      "en": "Provides Text-to-Speech conversion for YesImBot"
    },
    "service": {
      "required": [
        "yesimbot"
      ]
    }
  }
}
